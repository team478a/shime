# Supabase Transaction pooler (port 6543) for the Vercel/Next.js runtime.
DATABASE_URL=postgresql://postgres.PROJECT_REF:DB_PASSWORD@REGION.pooler.supabase.com:6543/postgres?sslmode=require
# Supabase direct connection or Session pooler (port 5432) for migrations and seed.
DATABASE_MIGRATION_URL=postgresql://postgres.PROJECT_REF:DB_PASSWORD@REGION.pooler.supabase.com:5432/postgres?sslmode=require
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=server-only-service-role-key
SUPABASE_IMPORT_BUCKET=shime-private-imports
SUPABASE_CONCIERGE_BUCKET=shime-private-concierge
# unconfirmed / manual / daily / pitr. Confirm this in Dashboard > Database > Backups.
SUPABASE_BACKUP_MODE=unconfirmed
LINE_CHANNEL_ID=line-login-channel-id
LINE_CHANNEL_SECRET=messaging-api-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=messaging-api-channel-access-token
NEXT_PUBLIC_LIFF_ID=liff-id
SESSION_PEPPER=replace-with-at-least-32-random-characters
PASSWORD_PEPPER=replace-with-at-least-32-random-characters
LINK_TOKEN_PEPPER=replace-with-at-least-32-random-characters
QR_TOKEN_PEPPER=replace-with-at-least-32-random-characters
INTERNAL_JOB_SECRET=replace-with-at-least-32-random-characters
CRON_SECRET=use-the-same-value-as-internal-job-secret-on-vercel
SETTINGS_ENCRYPTION_KEY=base64-encoded-32-byte-random-key
OPENAI_API_KEY=server-only-openai-api-key
APP_URL=http://localhost:3000
APP_ENV=development
SEED_ADMIN_PASSWORD=replace-with-a-unique-strong-development-password
# Optional synthetic rehearsal records. Must remain 0 in production (0-200).
SEED_DEMO_PARTICIPANTS=0

# One-time administrator bootstrap. Password falls back to SEED_ADMIN_PASSWORD.
BOOTSTRAP_TENANT_CODE=shime
BOOTSTRAP_TENANT_NAME=SHIME
BOOTSTRAP_ADMIN_LOGIN_ID=admin
BOOTSTRAP_ADMIN_DISPLAY_NAME=SHIME administrator
BOOTSTRAP_ROTATE_PASSWORD=false

{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@shime/core": ["./packages/core/src/index.ts"],
      "@shime/core/*": ["./packages/core/src/*"],
      "@shime/db": ["./packages/db/src/index.ts"],
      "@shime/db/*": ["./packages/db/src/*"],
      "@shime/web/*": ["./apps/web/src/*"]
    }
  }
}

{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@shime/core": ["./packages/core/src/index.ts"],
      "@shime/core/*": ["./packages/core/src/*"],
      "@shime/db": ["./packages/db/src/index.ts"],
      "@shime/db/*": ["./packages/db/src/*"],
      "@shime/integrations": ["./packages/integrations/src/index.ts"],
      "@shime/integrations/*": ["./packages/integrations/src/*"],
      "@shime/notifications": ["./packages/notifications/src/index.ts"],
      "@shime/notifications/*": ["./packages/notifications/src/*"],
      "@shime/questionnaire": ["./packages/questionnaire/src/index.ts"],
      "@shime/questionnaire/*": ["./packages/questionnaire/src/*"],
      "@shime/web/*": ["./apps/web/src/*"]
    }
  }
}

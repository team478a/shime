{
  "name": "shime",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm docs:sync && pnpm --filter @shime/web dev",
    "build": "pnpm docs:sync && pnpm --filter @shime/web build",
    "docs:sync": "tsx scripts/sync-public-docs.ts",
    "lint": "pnpm --filter @shime/web lint && eslint packages tests",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "pnpm docs:sync && playwright test",
    "audit:dependencies": "pnpm audit --audit-level moderate",
    "readiness": "tsx scripts/readiness.ts",
    "readiness:strict": "tsx scripts/readiness.ts --strict",
    "rehearsal:verify-seating": "tsx scripts/verify-rehearsal-seating-draft.ts",
    "smoke:openai-dream": "tsx scripts/smoke-openai-dream.ts",
    "supabase:verify": "tsx scripts/verify-supabase.ts",
    "supabase:verify-storage": "tsx scripts/verify-supabase-storage.ts",
    "supabase:backup-readiness": "tsx scripts/check-backup-readiness.ts",
    "db:generate": "drizzle-kit generate --config packages/db/drizzle.config.ts",
    "db:migrate": "tsx packages/db/src/migrate.ts",
    "db:bootstrap-admin": "tsx packages/db/src/bootstrap-admin.ts",
    "db:verify-admin": "tsx scripts/verify-admin-bootstrap.ts",
    "db:seed": "tsx packages/db/src/seed.ts"
  },
  "dependencies": {
    "@line/liff": "^2.29.1",
    "@supabase/supabase-js": "^2.110.2",
    "argon2": "^0.44.0",
    "csv-parse": "^7.0.1",
    "drizzle-orm": "^0.45.2",
    "html5-qrcode": "^2.3.8",
    "next": "^16.2.11",
    "postgres": "^3.4.9",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "0.35.3",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@humanfs/core": "0.19.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "balanced-match": "1.0.2",
    "brace-expansion": "1.1.16",
    "concat-map": "0.0.1",
    "deep-is": "0.1.4",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.11",
    "estraverse": "5.3.0",
    "fast-deep-equal": "3.1.3",
    "fast-json-stable-stringify": "2.1.0",
    "fast-levenshtein": "2.0.6",
    "is-extglob": "2.1.1",
    "is-glob": "4.0.3",
    "isexe": "2.0.0",
    "json-schema-traverse": "0.4.1",
    "levn": "0.4.1",
    "locate-path": "6.0.0",
    "ms": "2.1.3",
    "p-limit": "3.1.0",
    "p-locate": "5.0.0",
    "path-exists": "4.0.0",
    "path-key": "3.1.1",
    "prelude-ls": "1.2.1",
    "shebang-command": "2.0.0",
    "shebang-regex": "3.0.0",
    "tsx": "^4.23.0",
    "type-check": "0.4.0",
    "typescript": "^5.9.3",
    "uri-js": "4.4.1",
    "vitest": "^4.1.10",
    "which": "2.0.2",
    "word-wrap": "1.2.5",
    "yocto-queue": "0.1.0"
  }
}
